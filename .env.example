# Copy to .env and fill from: Supabase → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Client profile: sahar-alsharq | al-rukn-al-yamani
VITE_CLIENT_KEY=al-rukn-al-yamani

# Use local client files until the new client's Supabase is ready.
# Set to "supabase" only after the selected client's DB has its own content.
VITE_CONTENT_SOURCE=local
